<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title }}</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://unpkg.com/htmx.org@2.0.4" integrity="sha384-HGfztofotfshcF7+8n44JQL2oJmowVChPTg48S+jvZoztPfvwD79OC/LTtG6dMp+" crossorigin="anonymous"></script>
  </head>

  <body>
    <div class="bg-red-600 border-b-2 p-2">
      <div>
        <h1 class="text-3xl font-bold">ECHO</h1>
      </div>
      <div>
        Dran Drauf Drueber
      </div>
    </div>
    {% if loggedIn %}
    <div class="bg-red-600 border-b-2 p-2">
      <a href="/announcements" class="hover:bg-red-500 rounded-md m-1 p-1">
        Ankuendigungen
      </a>
      <a href="/platoon" class="hover:bg-red-500 rounded-md m-1 p-1">
        Zug
      </a>
      <a href="/teams" class="hover:bg-red-500 rounded-md m-1 p-1">
        Teams
      </a>
      <a href="/profile" class="hover:bg-red-500 rounded-md m-1 p-1">
        Profil
      </a>
    </div>
    {% endif %}
    <div>
      {% block content %} {% endblock content %}
    </div>
  </body>
</html>
